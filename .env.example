# ------------------------------------------------------------------------------
# LumenForge Environment Variables
# Copy file này thành .env.local và điền các giá trị thực tế để chạy ở localhost
# KHÔNG BAO GIỜ commit file .env.local lên Git!
# ------------------------------------------------------------------------------

# --- SUPABASE (Authentication & Database) ---
# URL của Supabase Project (Vào Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Role Key dùng cho Admin (Vào Project Settings > API > service_role / secret)
# Lưu ý: Không dùng Anon/Public key ở đây vì Vercel Function cần quyền Admin để bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# --- PAYOS (Hệ thống thanh toán VietQR) ---
# Lấy từ giao diện quản lý cổng thanh toán PayOS
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
